# Godot build cache
godot/.godot/

# .NET build output
godot/.mono/
godot/bin/
godot/obj/
# Story 1.10a: also cover the nested Godot-free test project (godot/ProjectChimera.Sim.Tests/bin|obj)
# and any other nested build output, so build artifacts can never be committed by accident.
**/bin/
**/obj/

# VS/Rider IDE files
.vs/
*.user
*.suo
.idea/

# OS junk
.DS_Store
Thumbs.db

# Local Claude Code permissions (machine-specific)
.claude/settings.local.json
